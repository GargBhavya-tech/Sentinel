# VITE_API_URL: base URL of the Sentinel FastAPI backend.
# Used by vite.config.ts to configure the dev-server proxy for /api, /cases,
# /graph, /audit, /health — this is what makes the console CORS-free in dev.
#
# Local (no Docker):        VITE_API_URL=http://localhost:8000   (default if unset)
# docker-compose:            VITE_API_URL=http://backend:8000     (set automatically by docker-compose.yml)
VITE_API_URL=http://localhost:8000
