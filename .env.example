# ── Slack App ─────────────────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps → your app → OAuth & Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here   # only needed for Socket Mode (local dev)

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: matches the docker-compose.yml service below
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# ── Security ──────────────────────────────────────────────────────────────────
# HMAC pepper for format-preserving PII pseudonymization (ticket #4)
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
PII_HMAC_PEPPER=change-me-to-a-strong-random-value

# ── Optional: OpenAI (for real LLM agents — not needed for Phase 0) ──────────
# OPENAI_API_KEY=sk-...

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
